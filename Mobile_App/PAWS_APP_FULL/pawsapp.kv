<ConnectBLEScreen>:
    BoxLayout:
        orientation: 'vertical'
        Label: ## title of the screen
            text:'Connect Screen'
            id: title_Lable 
            color: 1 , 0 , 0 , 1
            size_hint_y: None
            height: 50
            bold: True
        BoxLayout: ## navigation buttons
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
                disabled: True
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
            Button:
                text: 'Control'
                on_press: root.manager.current = 'control_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        GridLayout: ## content of the screen
            cols: 2
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            Label:
                bold: True
                text: 'Scan for Devices'
            Button:
                id: scan_button
                text: 'Scan'
                on_press: root.scan_button_pressed()
            Label:
                bold: True
                text: 'Available Devices'
            Spinner:
                disabled: True
                id: device_spinner
                text: 'Select Device'
                values: []
                on_text: root.device_selected(self.text)
            Label:
                bold: True
                text: 'Connect to Device'
            Button:
                id: connect_button
                text: 'Connect'
                on_press: root.connect_button_pressed()
                disabled: True
            Label:
                bold: True
                text: 'Disconnect from Device'
            Button:
                id: disconnect_button
                text: 'Disconnect'
                on_press: root.disconnect_button_pressed()
                disabled: True


<DataScreen>:
    BoxLayout:
        orientation: 'vertical'
        Label:
            text:'Data Screen'
            id: title_Lable 
            size_hint_y: None
            height: 50
            bold: True
        BoxLayout: ## navigation buttons
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
                disabled: True
            Button:
                text: 'Control'
                on_press: root.manager.current = 'control_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        ## content of the screen
        BoxLayout:
            orientation:'horizontal'
            BoxLayout: ## Data from the embedded system
                orientation:'vertical'
                Label: 
                    bold: True
                    text: 'Sensor Data Live Updates'
                    size_hint_y: None
                    height: 50
                GridLayout: ## sensor data display
                    cols: 2
                    default_row_height: 40
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    Label:
                        text: 'Temperature:'
                    Label:
                        id: temp_label
                        text: 'N/A'
                    Label:
                        text: 'Humidity:'
                    Label:
                        id: humidity_label
                        text: 'N/A'
                    Label:
                        text: 'Wind Speed:'
                    Label:
                        id: wind_speed_label
                        text: 'N/A'
                    Label:
                        text: 'Rainfall:'
                    Label:
                        id: rainfall_label
                        text: 'N/A'
                    Label:
                        text:'Light level'
                    Label:
                        id: light_level_label
                        text: 'N/A'
                    Button:
                        text: 'Start'
                        on_press: root.start_data_updates()
                    Button:
                        text: 'Stop'
                        on_press: root.stop_data_updates()
            BoxLayout: ## Data from the Wheather
                orientation:'vertical'
                Label:
                    text:'Geographical Data'
                    bold: True
                    size_hint_y: None
                    height: 50
                GridLayout:
                    cols: 2
                    default_row_height: 40
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    Label:
                        text:'ON:'
                    Label:
                        text:'N/A'
                        id: weather_Date
                    Label:
                        text:'Temp:'
                    Label:
                        text:'N/A'
                        id: weather_temp
                    Label:
                        text:'Humidity:'
                    Label:
                        text:'N/A'
                        id: weather_Humidity
                    Label:
                        text:'Wind:'
                    Label:
                        text:'N/A'
                        id: weather_Wind
                    Label:
                        text:'chance Of Rain:'
                    Label:
                        text:'N/A'
                        id: weather_Rain
                TextInput:
                    bold: True
                    size_hint_y: None
                    height: 40
                    id: 'id'
                    text: 'Southampton'
                    hint_text: 'Location'
                    id: data_location
                    font_size: 20


<ControlScreen>
    BoxLayout:
        orientation: 'vertical'
        Label:
            text:'Control Screen'
            size_hint_y: None
            id: title_Lable 
            height: 50
            bold: True
        BoxLayout: ## navigation buttons
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
                
            Button:
                text: 'Control'
                on_press: root.manager.current = 'control_screen'
                disabled: True
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        ## content of the screen
        Label: 
            bold: True
            text: 'Sensor Data Live Updates'
            size_hint_y: None
            height: 30
        BoxLayout: ## sensor data display
            orientation:'horizontal'
            size_hint_y: None
            height: 30
            Label:
                text:'Temp: '
                id: temp_label
            Label:
                text:'Humid:'
                id: humidity_label
            Label:
                text:'Wind: '
                id: wind_speed_label
            Label:
                text:'Rain: '
                id: rainfall_label
            Label:
                text:'Light: '
                id: light_level_label
        Label:
            text:'Set Points'
            size_hint_y: None
            height: 30
            bold: True
        GridLayout: ## Set points
            cols: 3
            #pos_hint: {"center_x": 0.5, "center_y": 0.5}
            Label: ## row 1
                text: 'Temperature:'
            TextInput:
                id: temp_setpoint
                text: 'N/A'
                multiline: False
            Label:
                text:'*C'
            Label: ## row 2
                text: 'Temperature hystereses:'
            TextInput:
                id: temp_hysteresis
                text: 'N/A'
                multiline: False
            Label:
                text:'*C'
            Label: ## row 3
                text: 'Humidity:'
            TextInput:
                id: humidity_setpoint
                text: 'N/A'
                multiline: False
            Label:
                text:'%'
            Label: ## row 4
                text: 'Humidity hystereses:'
            TextInput:
                id: humidity_hysteresis
                text: 'N/A'
                multiline: False
            Label:
                text:'%'
            Label: ## row 5
                text: 'Wind speed Max:'
            TextInput:
                id: wind_speed_max
                text: 'N/A'
                multiline: False
            Label:
                text:'mph'
            Label: ## row 6
                text: 'Light Min:'
            TextInput:
                id: light_min
                text: 'N/A'
                multiline: False
            Label:
                text:'%'

        Label:
            text:'Manual controls'
            size_hint_y: None
            height: 30
            bold: True
        GridLayout: ## control buttons
            size_hint_y: None
            default_row_height: 30
            cols: 4
            Label:
                text:'Lights'
            Button:
                text: 'Override enable'
                #size_hint_y: None
                id: light_override
                on_press:root.Toggle_Light_Override()
            Button:
                text: 'Light toggle'
                #size_hint_y: None
                id: light_toggle
                disabled: True
                on_press:root.Toggle_Light()
            Label:
                text:'Current state'
                id: light_state
            Label:
                text: 'Windows'
            Button:
                text: 'Override enable'
                #size_hint_y: None
                id: window_override
                on_press:root.Toggle_Window_Override()
            Button:
                text: 'Window toggle'
                #size_hint_y: None
                id: window_toggle
                disabled: True
                on_press: root.Toggle_Window()
            Label:
                text:'Current state'
                id: window_state
        Label: 
            text: 'Weather Monitoring'
            size_hint_y: None
            bold: True
            height: 30
        Button:
            size_hint_y: None
            height: 50
            text: 'Auto Control'
            id: Weather_Monitoring_Toggle
            on_press: root.Weather_Updater_Toggle()

    
<SettingsScreen>
    BoxLayout:
        orientation: 'vertical'
        Label:
            text:'Settings Screen'
            size_hint_y: None
            id: title_Lable 
            height: 50
            bold: True
        BoxLayout: ## navigation buttons
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
            Button:
                text: 'Control'
                on_press: root.manager.current = 'control_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
                disabled: True
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        
        GridLayout:
            cols: 3
            default_row_height: 40
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            Label:
                text:'Clock'
            TextInput:
                id: clock_settingraw
                text: 'N/A'
                multiline: False
            Spinner:
                id: clock_setting
                text: 'Select Clock Scale'
                values: ['Seconds', 'Minutes', 'Hours']
            Label:
                text:'LCD Back Light time out'
            TextInput:
                id: lcd_timeout_raw
                text: 'N/A'
                multiline: False
            Spinner:
                id: lcd_timeout
                text: 'Select LCD Scale'
                values: ['Seconds', 'Minutes', 'Hours']
        Button:
            text: 'Lock LCD'
            id: lcd_lock
        Button:
            text: 'Debug Enable'
            id: debug_enable
        Label:
            text:'Service Name'
            id: service_name
        Label:
            text:'Local Name'
            id: local_name

<DebugScreen>
    BoxLayout:
        orientation: 'vertical'
        Label:
            text:'Debug Screen'
            size_hint_y: None
            height: 50
            bold: True
        BoxLayout: ## navigation buttons top
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
            Button:
                text: 'Control'
                on_press: root.manager.current = 'control_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
                disabled: True
        BoxLayout: ## navigation buttons debug
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Load Log'
                on_press: root.manager.current = 'debug_screen'
                disabled: True
            Button:
                text: 'Save Log'
                on_press: root.manager.current = 'debug_screen_save'
        Label: ## File location path top of screen
            text: fc.path
            size_hint_y: None
            height: 30  
        BoxLayout: ## Split screen 
            orientation:'horizontal'
            BoxLayout: ## File chooser stuff
                orientation:'vertical'
                BoxLayout:
                    size_hint_y: None
                    height: 30

                    Button:
                        text: 'Icon View'
                        on_press: fc.view_mode = 'icon'
                    Button:
                        text: 'List View'
                        on_press: fc.view_mode = 'list'

                FileChooser:
                    id: fc
                    FileChooserIconLayout
                    FileChooserListLayout
                Button:
                    text: 'Open'
                    size_hint_y: None
                    height: 30
                    on_press: root.load(fc.path, fc.selection)
            BoxLayout: ## Text Output
                orientation:'vertical'
                Label:
                    text:'Contents'
                    size_hint_y: None
                    height: 30
                TextInput:
                    id: debug_text
                    text: ''
                    hint_text: 'debug text'  

        
<DebugScreenSave>
    BoxLayout:
        orientation: 'vertical'
        Label:
            text:'Debug Screen'
            size_hint_y: None
            height: 50
            bold: True
        BoxLayout: ## navigation buttons top
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
            Button:
                text: 'Control'
                on_press: root.manager.current = 'control_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
                disabled: True
        BoxLayout: ## navigation buttons debug
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Load Log'
                on_press: root.manager.current = 'debug_screen'
            Button:
                text: 'Save Log'
                on_press: root.manager.current = 'debug_screen_save'
                disabled: True
        BoxLayout:
            size: root.size
            pos: root.pos
            orientation: "vertical"
            FileChooserListView:
                id: filechooser
                on_selection: text_input.text = self.selection and self.selection[0] or ''

            TextInput:
                id: text_input
                size_hint_y: None
                height: 30
                multiline: False

            BoxLayout:
                size_hint_y: None
                height: 30
                Button:
                    text: "Cancel"
                    on_release: root.cancel()

                Button:
                    text: "Save"
                    on_release: root.save(filechooser.path, text_input.text)