<ConnectBLEScreen>:

    BoxLayout:
        orientation: 'vertical'
        Label: ## title of the screen
            text:'Connect Screen'
            size_hint_y: None
            height: 50
            bold: True
        BoxLayout: ## navigation buttons
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
                disabled: True
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        GridLayout: ## content of the screen
            cols: 2
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            Label:
                bold: True
                text: 'Scan for Devices'
            Button:
                id: scan_button
                text: 'Scan'
                on_press: root.scan_button_pressed()
            Label:
                bold: True
                text: 'Available Devices'
            Spinner:
                disabled: True
                id: device_spinner
                text: 'Select Device'
                values: []
                on_text: root.device_selected(self.text)
            Label:
                bold: True
                text: 'Connect to Device'
            Button:
                id: connect_button
                text: 'Connect'
                on_press: root.connect_button_pressed()
                disabled: True
            Label:
                bold: True
                text: 'Disconnect from Device'
            Button:
                id: disconnect_button
                text: 'Disconnect'
                on_press: root.disconnect_button_pressed()
                disabled: True


