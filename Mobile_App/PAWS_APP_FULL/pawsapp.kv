                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        ## content of the screen
        Label: 
            bold: True
            text: 'Sensor Data Live Updates'
            size_hint_y: None
            height: 50
        Label:
            text:''
            


