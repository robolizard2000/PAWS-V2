<ConnectBLEScreen>:

    BoxLayout:
        orientation: 'vertical'
        Label: ## title of the screen
            text:'Connect Screen'
            size_hint_y: None
            height: 50
            bold: True
        BoxLayout: ## navigation buttons
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
                disabled: True
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
            Button:
                text: 'Control'
                on_press: root.manager.current = 'control_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        GridLayout: ## content of the screen
            cols: 2
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            Label:
                bold: True
                text: 'Scan for Devices'
            Button:
                id: scan_button
                text: 'Scan'
                on_press: root.scan_button_pressed()
            Label:
                bold: True
                text: 'Available Devices'
            Spinner:
                disabled: True
                id: device_spinner
                text: 'Select Device'
                values: []
                on_text: root.device_selected(self.text)
            Label:
                bold: True
                text: 'Connect to Device'
            Button:
                id: connect_button
                text: 'Connect'
                on_press: root.connect_button_pressed()
                disabled: True
            Label:
                bold: True
                text: 'Disconnect from Device'
            Button:
                id: disconnect_button
                text: 'Disconnect'
                on_press: root.disconnect_button_pressed()
                disabled: True


<DataScreen>:
    BoxLayout:
        orientation: 'vertical'
        Label:
            text:'Data Screen'
            size_hint_y: None
            height: 50
            bold: True
        BoxLayout: ## navigation buttons
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
                disabled: True
            Button:
                text: 'Control'
                on_press: root.manager.current = 'control_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        ## content of the screen
        Label: 
            bold: True
            text: 'Sensor Data Live Updates'
            size_hint_y: None
            height: 50
        GridLayout:
            cols: 2
            default_row_height: 40
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            Label:
                text: 'Temperature:'
            Label:
                id: temp_label
                text: 'N/A'
            Label:
                text: 'Humidity:'
            Label:
                id: humidity_label
                text: 'N/A'
            Label:
                text: 'Wind Speed:'
            Label:
                id: wind_speed_label
                text: 'N/A'
            Label:
                text: 'Rainfall:'
            Label:
                id: rainfall_label
                text: 'N/A'
            Label:
                text:'Light level'
            Label:
                id: light_level_label
                text: 'N/A'
            Button:
                text: 'Start'
                on_press: root.start_data_updates()
            Button:
                text: 'Stop'
                on_press: root.stop_data_updates()

