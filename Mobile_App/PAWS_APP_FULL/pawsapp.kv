<ConnectBLEScreen>:
    BoxLayout:
        orientation: 'vertical'
        Label: ## title of the screen
            text:'Connect Screen'
            size_hint_y: None
            height: 50
            bold: True
        BoxLayout: ## navigation buttons
            orientation:'horizontal'
            size_hint_y: None
            height: 50
            Button:
                text: 'Connect'
                on_press: root.manager.current = 'connect_ble'
                disabled: True
            Button:
                text: 'Data'
                on_press: root.manager.current = 'data_screen'
            Button:
                text: 'Settings'
                on_press: root.manager.current = 'settings_screen'
            Button:
                text: 'Debug'
                on_press: root.manager.current = 'debug_screen'
        BoxLayout: ## content of the screen
            Label:
                bold: True
                text: 'Settings go here'


